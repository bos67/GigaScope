# GigaScope public configuration template.
# Copy to .env and replace the password. Never commit .env.

OUROBOROS_API_URL=http://localhost:8765
GIGASCOPE_SPA_HOST=127.0.0.1
GIGASCOPE_SPA_PORT=8099

# Used by this distribution's init/reset/seed scripts.
NEO4J_BOLT_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-before-first-run
NEO4J_CONTAINER=gigascope-neo4j
NEO4J_IMAGE=neo4j:5

# Set the same values in the Ouroboros process before it starts.
GIGASCOPE_NEO4J_URI=bolt://localhost:7687
GIGASCOPE_NEO4J_USER=neo4j
GIGASCOPE_NEO4J_PASS=change-me-before-first-run

# Optional: enables POST /api/gigascope/logs/llm-analyze.
# OPENROUTER_API_KEY=
